; Godot 4.6.3 — RPG Streaming Starter (data-driven full-world base).
; Compatibility/WebGL2 + nothreads. IDENTICAL render config to godot-templates/3d.
; Areas + their .glb stream from R2 at runtime; world.json/quests.json are loose files
; served next to index.html (NOT packed), so chat edits can rewrite them with no re-export.

config_version=5

[application]

config/name="Godot RPG Streaming Starter"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

AudioManager="*res://audio_manager.gd"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_mouse_from_touch=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
renderer/rendering_method.web="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
